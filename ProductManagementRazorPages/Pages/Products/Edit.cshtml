@page "{id:int}"
@model ProductManagementRazorPages.Pages.Products.EditModel
@{
    ViewData["Title"] = "Edit Product";
    bool isAdmin = HttpContext.Session.GetInt32("MemberRole") == 1;
}

<h2>Edit Product</h2>
<hr />

<div class="row">
    <div class="col-md-6">
        <form method="post">
            <input type="hidden" asp-for="Product.ProductID" />
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="mb-3">
                <label asp-for="Product.ProductName" class="form-label"></label>
                @if (isAdmin)
                {
                    <input asp-for="Product.ProductName" class="form-control" />
                }
                else
                {
                    <input asp-for="Product.ProductName" class="form-control" readonly="readonly" />
                }
                <span asp-validation-for="Product.ProductName" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Product.CategoryID" class="form-label">Category</label>
                @if (isAdmin)
                {
                    <select asp-for="Product.CategoryID" asp-items="Model.CategoryList" class="form-select">
                        <option value="">-- Select Category --</option>
                    </select>
                }
                else
                {
                    <!-- For non-admin, we just show a text box with the value, or make select disabled. Since we don't have Product.Category directly in the model unless included, a disabled select is easier. -->
                    <select asp-for="Product.CategoryID" asp-items="Model.CategoryList" class="form-select" disabled="disabled">
                        <option value="">-- Select Category --</option>
                    </select>
                    <input type="hidden" asp-for="Product.CategoryID" />
                }
                <span asp-validation-for="Product.CategoryID" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Product.UnitsInStock" class="form-label"></label>
                @if (isAdmin)
                {
                    <input asp-for="Product.UnitsInStock" class="form-control" type="number" min="0" />
                }
                else
                {
                    <input asp-for="Product.UnitsInStock" class="form-control" type="number" min="0" readonly="readonly" />
                }
                <span asp-validation-for="Product.UnitsInStock" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Product.UnitPrice" class="form-label"></label>
                <input asp-for="Product.UnitPrice" class="form-control" type="number" min="0.01" step="0.01" />
                <span asp-validation-for="Product.UnitPrice" class="text-danger"></span>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">Save</button>
                <a asp-page="Index" class="btn btn-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}

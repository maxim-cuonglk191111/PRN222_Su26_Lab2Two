@page
@model ProductManagementRazorPages.Pages.Products.IndexModel
@{
    ViewData["Title"] = "Products";
    bool isAdmin = HttpContext.Session.GetInt32("MemberRole") == 1;
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Products</h2>
    @if (isAdmin)
    {
        <a asp-page="Create" class="btn btn-success">+ New Product</a>
    }
</div>

@if (!Model.Products.Any())
{
    <div class="alert alert-info">No products found.</div>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped table-hover align-middle" id="productTable">
            <thead class="table-dark">
                <tr>
                    <th>#</th>
                    <th>Product Name</th>
                    <th>Category</th>
                    <th class="text-center">Units in Stock</th>
                    <th class="text-end">Unit Price</th>
                    <th class="text-center">Actions</th>
                </tr>
            </thead>
            <tbody id="productTableBody">
                @foreach (var item in Model.Products)
                {
                    <tr>
                        <td>@item.ProductID</td>
                        <td>@item.ProductName</td>
                        <td>@(item.Category?.CategoryName ?? "—")</td>
                        <td class="text-center">
                            @if (item.UnitsInStock.HasValue)
                            {
                                <span class="badge @(item.UnitsInStock < 10 ? "bg-danger" : "bg-success")">
                                    @item.UnitsInStock
                                </span>
                            }
                            else
                            {
                                <span class="text-muted">—</span>
                            }
                        </td>
                        <td class="text-end">
                            @(item.UnitPrice.HasValue ? item.UnitPrice.Value.ToString("C") : "—")
                        </td>
                        <td class="text-center">
                            <a asp-page="Edit" asp-route-id="@item.ProductID"
                               class="btn btn-sm btn-outline-warning">Edit</a>
                            @if (isAdmin)
                            {
                                <a asp-page="Delete" asp-route-id="@item.ProductID"
                                   class="btn btn-sm btn-outline-danger">Delete</a>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@section Scripts {
    <script src="~/js/microsoft/signalr/dist/browser/signalr.js"></script>
    <script src="~/js/site.js"></script>
}

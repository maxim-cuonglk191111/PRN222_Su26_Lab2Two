@page
@model ProductManagementRazorPages.Pages.LoginModel
@{
    ViewData["Title"] = "Login";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Login - Product Management</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
</head>
<body class="bg-light">
<div class="container d-flex justify-content-center align-items-center" style="min-height:100vh;">
    <div class="card shadow p-4" style="width:380px;">
        <h4 class="card-title text-center mb-4">Product Management Login</h4>
        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="alert alert-danger">@Model.ErrorMessage</div>
        }
        <form method="post">
            <div class="mb-3">
                <label class="form-label">Member ID</label>
                <input asp-for="EmailAddress" class="form-control" type="email" required />
            </div>
            <div class="mb-3">
                <label class="form-label">Password</label>
                <input asp-for="MemberPassword" class="form-control" type="password" required />
            </div>
            <button type="submit" class="btn btn-primary w-100">Login</button>
        </form>
    </div>
</div>
</body>
</html>
